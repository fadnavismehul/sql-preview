{
  "name": "sql-preview-postgres",
  "version": "1.0.0",
  "description": "PostgreSQL connector for SQL Preview",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sql-preview-postgres": "./dist/cli.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --platform=node --format=cjs --external:pg && esbuild src/cli.ts --bundle --outfile=dist/cli.js --platform=node --format=cjs --external:pg --banner:js=\"#!/usr/bin/env node\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.0.0"
  }
}
