{
    "name": "sql-preview-snowflake",
    "version": "1.0.0",
    "description": "Snowflake connector for SQL Preview",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "sql-preview-snowflake": "./dist/cli.js"
    },
    "scripts": {
        "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --platform=node --format=cjs --external:snowflake-sdk && esbuild src/cli.ts --bundle --outfile=dist/cli.js --platform=node --format=cjs --external:snowflake-sdk --banner:js=\"#!/usr/bin/env node\"",
        "test": "jest --testPathPattern='__tests__/SnowflakeConnector\\.test\\.ts' --passWithNoTests",
        "test:integration": "jest --testPathPattern='__tests__/SnowflakeConnector\\.integration\\.test\\.ts' --testTimeout=120000 --passWithNoTests",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "@sql-preview/connector-api": "file:../sql-preview-connector-api",
        "snowflake-sdk": "^1.15.0"
    },
    "devDependencies": {
        "@types/jest": "^29.0.0",
        "@types/node": "^18.0.0",
        "@types/snowflake-sdk": "^1.6.24",
        "esbuild": "^0.19.0",
        "jest": "^29.0.0",
        "ts-jest": "^29.0.0",
        "typescript": "^5.0.0"
    }
}