{
  "name": "sql-preview-sqlite",
  "version": "1.0.0",
  "description": "SQLite connector for SQL Preview",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sql-preview-sqlite": "./dist/cli.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --platform=node --format=cjs --external:sql.js && esbuild src/cli.ts --bundle --outfile=dist/cli.js --platform=node --format=cjs --external:sql.js --banner:js=\"#!/usr/bin/env node\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sql-preview/connector-api": "file:../sql-preview-connector-api",
    "sql.js": "^1.14.0"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.9",
    "esbuild": "^0.19.0",
    "typescript": "^5.0.0"
  }
}
