{
    "name": "sql-preview-mssql",
    "version": "1.0.0",
    "description": "Microsoft SQL Server / Azure SQL connector for SQL Preview",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "sql-preview-mssql": "./dist/cli.js"
    },
    "scripts": {
        "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --platform=node --format=cjs --external:mssql && esbuild src/cli.ts --bundle --outfile=dist/cli.js --platform=node --format=cjs --external:mssql --banner:js=\"#!/usr/bin/env node\"",
        "test": "jest --testPathPattern='__tests__/MSSQLConnector\\.test\\.ts' --passWithNoTests",
        "test:integration": "jest --testPathPattern='__tests__/MSSQLConnector\\.integration\\.test\\.ts' --testTimeout=180000 --passWithNoTests",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "@sql-preview/connector-api": "file:../sql-preview-connector-api",
        "mssql": "^11.0.1"
    },
    "devDependencies": {
        "@testcontainers/mssqlserver": "^11.12.0",
        "@types/jest": "^29.0.0",
        "@types/node": "^18.0.0",
        "esbuild": "^0.19.0",
        "jest": "^29.0.0",
        "testcontainers": "^10.13.0",
        "ts-jest": "^29.0.0",
        "typescript": "^5.0.0"
    }
}