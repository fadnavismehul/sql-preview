{
  "name": "sql-preview-duckdb",
  "version": "1.0.0",
  "description": "DuckDB connector for SQL Preview",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --platform=node --format=cjs --external:@duckdb/node-api && esbuild src/cli.ts --bundle --outfile=dist/cli.js --platform=node --format=cjs --external:@duckdb/node-api --banner:js=\"#!/usr/bin/env node\""
  },
  "dependencies": {
    "@duckdb/node-api": "^1.4.4-r.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sql-preview/connector-api": "file:../sql-preview-connector-api"
  },
  "devDependencies": {
    "esbuild": "^0.19.0",
    "typescript": "^5.0.0"
  }
}
